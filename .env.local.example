# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_ variables are visible in the browser — like Flask's non-secret app.config entries.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Server-only secrets — never prefixed with NEXT_PUBLIC_
# Like environment variables you'd read with os.getenv() in Python
GITHUB_TOKEN=ghp_your_personal_access_token        # Optional — raises rate limit from 60 to 5000 req/hr
GITHUB_USERNAME=your-github-username               # Whose repos to show on the dashboard

# Supabase service-role key — bypasses RLS (use only server-side, never in the browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe — all four are required for billing to work
STRIPE_SECRET_KEY=sk_test_...                      # Stripe Dashboard > Developers > API keys
STRIPE_WEBHOOK_SECRET=whsec_...                    # Stripe Dashboard > Webhooks > signing secret
STRIPE_STARTER_PRICE_ID=price_...                  # Price ID for the ₹1,499/month Starter plan
STRIPE_PRO_PRICE_ID=price_...                      # Price ID for the ₹4,499/month Pro plan

# Public site URL — used to build redirect URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
